        "import pickle\n",
        "import os\n",
        "\n",
        "# 1. 기본 경로 설정\n",
        "base_path = \"/content/drive/MyDrive/USTC-TFC2016-processed\"\n",
        "\n",
        "# 비교할 3가지 파일 경로 명시\n",
        "files_to_compare = {\n",
        "    \"원본 통합 데이터 (ustc_tfc2016.pkl)\": f\"{base_path}/ustc_tfc2016.pkl\",\n",
        "    \"학습용 원본 데이터 (train.pkl)\": f\"{base_path}/train.pkl\",\n",
        "    \"학습용 20% 샘플링 데이터 (train_small.pkl)\": f\"{base_path}/train_small.pkl\"\n",
        "}\n",
        "\n",
        "def analyze_pkl(file_path, name):\n",
        "    print(f\"\\n==================================================\")\n",
        "    print(f\"[{name}] 파일 분석 결과\")\n",
        "    print(f\"==================================================\")\n",
        "\n",
        "    if not os.path.exists(file_path):\n",
        "        print(f\"에러: {file_path} 경로에 파일이 없음\")\n",
        "        return None\n",
        "\n",
        "    # 파일 불러오기\n",
        "    with open(file_path, \"rb\") as f:\n",
        "        data = pickle.load(f)\n",
        "\n",
        "    # 1. 전체 데이터 구조 분석\n",
        "    print(f\"🔹 전체 데이터 타입: {type(data)}\")\n",
        "    print(f\"🔹 전체 샘플(행) 개수: {len(data):,}개\")\n",
        "\n",
        "    # 데이터가 비어있지 않다면 첫 번째 샘플 분석\n",
        "    if len(data) > 0:\n",
        "        first_sample = data[0]\n",
        "        print(f\"\\n🔸 [첫 번째 샘플 구조]\")\n",
        "        print(f\"   - 샘플 데이터 타입: {type(first_sample)}\")\n",
        "\n",
        "        if isinstance(first_sample, (list, tuple)):\n",
        "            print(f\"   - 컬럼(요소) 개수: {len(first_sample)}개\")\n",
        "            print(f\"   - 각 컬럼의 데이터 타입 예시: {[type(x).__name__ for x in first_sample[:5]]} ...\")\n",
        "        elif isinstance(first_sample, dict):\n",
        "            print(f\"   - 딕셔너리 키(Key) 목록: {list(first_sample.keys())}\")\n",
        "\n",
        "        print(f\"\\n🔸 [실제 데이터 샘플 값 (첫 1개 행)]\")\n",
        "        # 데이터가 너무 길게 출력되어 가독성이 떨어지는 것을 방지\n",
        "        if isinstance(first_sample, list) and len(first_sample) > 5:\n",
        "            print(f\"   {first_sample[:2]} ... [총 {len(first_sample)}개 중 일부 출력] ... {first_sample[-1:]}\")\n",
        "        else:\n",
        "            print(f\"   {first_sample}\")\n",
        "    else:\n",
        "        print(\"파일 안에 데이터가 비어있음\")\n",
        "\n",
        "    return data\n",
        "\n",
        "# 반복문을 돌며 세 파일 차례대로 분석 수행\n",
        "for display_name, target_path in files_to_compare.items():\n",
        "    analyze_pkl(target_path, display_name)"
      ]
    },
