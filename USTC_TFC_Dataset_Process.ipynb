        "import pickle\n",
        "import random\n",
        "import os\n",
        "import gc\n",
        "\n",
        "# 1. 경로 설정\n",
        "base_path = \"/content/drive/MyDrive/USTC-TFC2016-processed\"\n",
        "input_path = f\"{base_path}/ustc_tfc2016.pkl\"\n",
        "output_path = f\"{base_path}/finetune.pkl\"\n",
        "\n",
        "print(f\"1. 원본 통합 데이터 로딩 중: {os.path.basename(input_path)}\")\n",
        "if not os.path.exists(input_path):\n",
        "    print(f\"에러: {input_path} 경로에 파일이 없음\")\n",
        "else:\n",
        "    with open(input_path, \"rb\") as f:\n",
        "        data = pickle.load(f)\n",
        "\n",
        "    # 2. 10% 랜덤 샘플링 진행\n",
        "    ratio = 0.1\n",
        "    num_samples = int(len(data) * ratio)\n",
        "    print(f\"2. 랜덤 10% 추출 중... (총 {len(data):,}개 -> 목표 {num_samples:,}개)\")\n",
        "\n",
        "    sampled_data = random.sample(data, num_samples)\n",
        "\n",
        "    # 메모리 절약을 위해 대용량 원본 데이터 즉시 삭제\n",
        "    del data\n",
        "    gc.collect()\n",
        "\n",
        "    # 3. 구글 드라이브에 새로운 pkl 파일로 저장\n",
        "    print(f\"3. 구글 드라이브에 저장 중: {os.path.basename(output_path)}\")\n",
        "    with open(output_path, \"wb\") as f:\n",
        "        pickle.dump(sampled_data, f)\n",
        "\n",
        "    print(f\"모든 작업 완료! 생성된 데이터 개수: {len(sampled_data):,}개\")"
      ]
    },
