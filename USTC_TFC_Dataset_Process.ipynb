      "source": [
        "import pandas as pd\n",
        "import glob\n",
        "import os\n",
        "import numpy as np\n",
        "import pickle\n",
        "\n",
        "# 1. 파일 경로 및 저장 경로 설정\n",
        "input_folder = '/content/cic-ids2018' # 방금 압축 푸신 폴더 경로\n",
        "save_dir = '/content/drive/MyDrive/CIC-IDS2018-processed'\n",
        "os.makedirs(save_dir, exist_ok=True)\n",
        "\n",
        "# 폴더 내의 모든 parquet 파일 목록 가져오기\n",
        "all_files = glob.glob(os.path.join(input_folder, \"*.parquet\"))\n",
        "print(f\"총 {len(all_files)}개의 Parquet 파일을 찾았습니다. 병합을 시작합니다...\\n\")\n",
        "\n",
        "# 2. 모든 파일 순회하며 읽기 및 병합\n",
        "df_list = []\n",
        "for file in all_files:\n",
        "    file_name = os.path.basename(file)\n",
        "    print(f\" 읽는 중: {file_name}\")\n",
        "    # parquet 파일 읽기\n",
        "    df = pd.read_parquet(file)\n",
        "    df_list.append(df)\n",
        "\n",
        "print(\"\\n모든 파일을 하나로 합치는 중...\")\n",
        "merged_df = pd.concat(df_list, ignore_index=True)\n",
        "\n",
        "# 3. 데이터 정제 (결측치 및 무한대 값 제거)\n",
        "print(\"데이터 정제 중 (무한대 값, 빈칸 제거)...\")\n",
        "merged_df.replace([np.inf, -np.inf], np.nan, inplace=True)\n",
        "merged_df.dropna(inplace=True)\n",
        "\n",
        "print(f\"병합 및 정제 완료! 총 데이터 개수: {len(merged_df):,}개\\n\")\n",
        "\n",
        "# 4. 메모리 초과 방지를 위한 1% 샘플링\n",
        "print(\"메모리 안전을 위해 1% 랜덤 샘플링 진행...\")\n",
        "sampled_df = merged_df.sample(frac=0.01, random_state=42)\n",
        "\n",
        "# 5. 리스트로 변환 및 PKL 저장\n",
        "print(\"파이썬 리스트 형태로 구조 변환 중...\")\n",
        "data_list = sampled_df.values.tolist()\n",
        "\n",
        "output_path = f'{save_dir}/cic2018_merged_small.pkl'\n",
        "print(f\"구글 드라이브에 PKL 파일로 저장 중: {output_path}\")\n",
        "\n",
        "with open(output_path, 'wb') as f:\n",
        "    pickle.dump(data_list, f)\n",
        "\n",
        "print(\"\\n🎉 모든 작업이 성공적으로 완료됨\")"
      ]
    },
