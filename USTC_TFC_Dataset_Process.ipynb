        "import pickle\n",
        "import numpy as np\n",
        "import os\n",
        "import random\n",
        "import gc\n",
        "\n",
        "def sanitize_and_flatten(obj):\n",
        "    \"\"\"NumPy 배열 제거 및 순수 리스트 구조로 완벽 변환 (사전학습 규격 일치)\"\"\"\n",
        "    if isinstance(obj, np.ndarray):\n",
        "        return obj.tolist()\n",
        "    elif isinstance(obj, dict):\n",
        "        return [sanitize_and_flatten(v) for v in obj.values()]\n",
        "    elif isinstance(obj, (list, tuple)):\n",
        "        return [sanitize_and_flatten(v) for v in obj]\n",
        "    return obj\n",
        "\n",
        "# 1. 경로 설정\n",
        "base_path = \"/content/drive/MyDrive/USTC-TFC2016-processed\"\n",
        "input_path = f\"{base_path}/ustc_tfc2016.pkl\"\n",
        "\n",
        "train_output_path = f\"{base_path}/finetune_train.pkl\"\n",
        "val_output_path = f\"{base_path}/finetune_val.pkl\"\n",
        "\n",
        "print(f\"1. 원본 통합 데이터 로딩 중: {os.path.basename(input_path)}\")\n",
        "if not os.path.exists(input_path):\n",
        "    print(f\"에러: {input_path} 경로에 파일이 없음\")\n",
        "else:\n",
        "    with open(input_path, \"rb\") as f:\n",
        "        data = pickle.load(f)\n",
        "\n",
        "    # 2. 10% 랜덤 샘플링\n",
        "    ratio = 0.1\n",
        "    num_samples = int(len(data) * ratio)\n",
        "    print(f\"2. 전체 데이터에서 랜덤 10% 추출 중... (총 {len(data):,}개 -> 목표 {num_samples:,}개)\")\n",
        "    sampled_data = random.sample(data, num_samples)\n",
        "\n",
        "    # 메모리 절약\n",
        "    del data\n",
        "    gc.collect()\n",
        "\n",
        "    # 3. 정화 및 평탄화 (NumPy 제거 + 순수 리스트화)\n",
        "    print(f\"🧹 3. 데이터 정화 및 사전학습 규격 일치화 작업 중...\")\n",
        "    clean_data = []\n",
        "    for row in sampled_data:\n",
        "        clean_data.append(sanitize_and_flatten(row))\n",
        "\n",
        "    del sampled_data\n",
        "    gc.collect()\n",
        "\n",
        "    # 4. 8:2 비율로 Train / Val 데이터 분할\n",
        "    print(f\"4. 정제된 데이터를 8:2 비율로 분할 중...\")\n",
        "    random.shuffle(clean_data) # 편향을 막기 위해 한 번 더 무작위 셔플\n",
        "\n",
        "    split_idx = int(len(clean_data) * 0.8)\n",
        "    train_data = clean_data[:split_idx]\n",
        "    val_data = clean_data[split_idx:]\n",
        "\n",
        "    del clean_data\n",
        "    gc.collect()\n",
        "\n",
        "    # 5. 최종 데이터 구글 드라이브에 각각 저장\n",
        "    print(f\"5. 구글 드라이브에 파일 저장 중...\")\n",
        "\n",
        "    with open(train_output_path, \"wb\") as f:\n",
        "        pickle.dump(train_data, f)\n",
        "    print(f\"   {os.path.basename(train_output_path)} 저장 완료! (개수: {len(train_data):,}개)\")\n",
        "\n",
        "    with open(val_output_path, \"wb\") as f:\n",
        "        pickle.dump(val_data, f)\n",
        "    print(f\"   {os.path.basename(val_output_path)} 저장 완료! (개수: {len(val_data):,}개)\")\n",
        "\n",
